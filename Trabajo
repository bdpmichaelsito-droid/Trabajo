<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TRANSNUPERSA S.A. - Gestión de Mantenimiento</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    body { background: #f3f4f6; }
    .hidden { display: none !important; }
    .card { transition: all 0.2s; }
    .card:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .badge { padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
  </style>
</head>
<body>

<div id="app" class="min-h-screen flex flex-col">
  <!-- NAVBAR -->
  <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
    <div class="container mx-auto flex justify-between items-center flex-wrap">
      <h1 class="text-2xl font-bold text-blue-700">🚛 TRANSNUPERSA S.A.</h1>
      <div id="authButtons" class="flex gap-2">
        <button onclick="showLogin()" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Iniciar Sesión</button>
        <button onclick="showRegister()" class="bg-gray-200 px-4 py-2 rounded hover:bg-gray-300">Registrarse</button>
      </div>
      <div id="userInfo" class="hidden flex items-center gap-4">
        <span id="userName" class="font-medium"></span>
        <span id="userRole" class="badge bg-gray-200 text-gray-800"></span>
        <button onclick="logout()" class="text-red-600 hover:text-red-800 text-sm">Cerrar Sesión</button>
      </div>
    </div>
  </nav>

  <!-- CONTENIDO PRINCIPAL -->
  <main class="container mx-auto p-4 flex-grow">
    <!-- PANTALLA DE LOGIN -->
    <div id="loginScreen" class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md mt-10">
      <h2 class="text-2xl font-bold mb-6">Iniciar Sesión</h2>
      <form onsubmit="login(event)">
        <div class="mb-4">
          <label class="block text-gray-700">Email</label>
          <input type="email" id="loginEmail" required class="w-full border p-2 rounded">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700">Contraseña</label>
          <input type="password" id="loginPassword" required class="w-full border p-2 rounded">
        </div>
        <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">Ingresar</button>
      </form>
      <p class="mt-4 text-center text-sm text-gray-600">¿No tienes cuenta? <a href="#" onclick="showRegister()" class="text-blue-600">Regístrate</a></p>
    </div>

    <!-- PANTALLA DE REGISTRO -->
    <div id="registerScreen" class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md mt-10 hidden">
      <h2 class="text-2xl font-bold mb-6">Registrarse</h2>
      <form onsubmit="register(event)">
        <div class="mb-4">
          <label class="block text-gray-700">Nombre</label>
          <input type="text" id="regName" required class="w-full border p-2 rounded">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700">Email</label>
          <input type="email" id="regEmail" required class="w-full border p-2 rounded">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700">Contraseña</label>
          <input type="password" id="regPassword" required class="w-full border p-2 rounded">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700">Rol (solo Admin puede asignar otros roles)</label>
          <select id="regRol" class="w-full border p-2 rounded">
            <option value="tecnico">Técnico</option>
            <option value="jefe">Jefe de Mantenimiento</option>
            <option value="supervisor">Supervisor</option>
            <option value="admin">Administrador</option>
          </select>
        </div>
        <button type="submit" class="w-full bg-green-600 text-white py-2 rounded hover:bg-green-700">Registrarse</button>
      </form>
      <p class="mt-4 text-center text-sm text-gray-600">¿Ya tienes cuenta? <a href="#" onclick="showLogin()" class="text-blue-600">Inicia Sesión</a></p>
    </div>

    <!-- DASHBOARD (solo visible cuando hay sesión) -->
    <div id="dashboard" class="hidden">
      <!-- Menú de navegación interno -->
      <div class="flex flex-wrap gap-2 mb-6 bg-white p-4 rounded-lg shadow">
        <button onclick="showSection('vehiculos')" class="px-4 py-2 bg-blue-100 hover:bg-blue-200 rounded">🚛 Vehículos</button>
        <button onclick="showSection('preventivos')" class="px-4 py-2 bg-green-100 hover:bg-green-200 rounded">🛠️ Preventivos</button>
        <button onclick="showSection('correctivos')" class="px-4 py-2 bg-yellow-100 hover:bg-yellow-200 rounded">🔧 Correctivos</button>
        <button onclick="showSection('ordenes')" class="px-4 py-2 bg-purple-100 hover:bg-purple-200 rounded">📋 Órdenes</button>
        <button onclick="showSection('historial')" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded">📜 Historial</button>
        <button onclick="showSection('reportes')" class="px-4 py-2 bg-red-100 hover:bg-red-200 rounded">📊 Reportes</button>
        <button onclick="showSection('alertas')" class="px-4 py-2 bg-orange-100 hover:bg-orange-200 rounded">🔔 Alertas</button>
        <!-- Admin-only -->
        <button id="adminUsersBtn" onclick="showSection('usuarios')" class="px-4 py-2 bg-indigo-100 hover:bg-indigo-200 rounded hidden">👥 Usuarios</button>
      </div>

      <!-- SECCIONES -->
      <div id="sectionVehiculos" class="section-content bg-white p-6 rounded-lg shadow">
        <h2 class="text-2xl font-bold mb-4">Gestión de Vehículos</h2>
        <button onclick="showForm('vehiculo')" class="bg-blue-600 text-white px-4 py-2 rounded mb-4">+ Agregar Vehículo</button>
        <div id="vehiculosList" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
        <div id="vehiculoForm" class="hidden mt-4 p-4 border rounded bg-gray-50">
          <h3 class="font-bold mb-2">Formulario Vehículo</h3>
          <form onsubmit="saveVehiculo(event)">
            <input type="hidden" id="vehiculoId">
            <div class="grid grid-cols-2 gap-2">
              <input type="text" id="vPlaca" placeholder="Placa" required class="border p-2 rounded">
              <input type="text" id="vMarca" placeholder="Marca" required class="border p-2 rounded">
              <input type="text" id="vModelo" placeholder="Modelo" required class="border p-2 rounded">
              <input type="number" id="vAnio" placeholder="Año" class="border p-2 rounded">
              <input type="text" id="vChasis" placeholder="Chasis" class="border p-2 rounded">
              <input type="text" id="vMotor" placeholder="Motor" class="border p-2 rounded">
              <input type="text" id="vTipo" placeholder="Tipo" class="border p-2 rounded">
              <input type="number" id="vCapacidad" placeholder="Capacidad (ton)" class="border p-2 rounded">
              <input type="text" id="vCombustible" placeholder="Combustible" class="border p-2 rounded">
              <input type="number" id="vKilometraje" placeholder="Kilometraje" class="border p-2 rounded">
              <input type="date" id="vFechaAdq" class="border p-2 rounded">
              <select id="vEstado" class="border p-2 rounded">
                <option value="activo">Activo</option>
                <option value="mantenimiento">En Mantenimiento</option>
                <option value="fuera_servicio">Fuera de Servicio</option>
              </select>
              <input type="text" id="vConductor" placeholder="Conductor" class="border p-2 rounded">
              <textarea id="vObservaciones" placeholder="Observaciones" class="border p-2 rounded col-span-2"></textarea>
            </div>
            <button type="submit" class="mt-2 bg-green-600 text-white px-4 py-2 rounded">Guardar</button>
            <button type="button" onclick="hideForm('vehiculo')" class="mt-2 bg-gray-400 text-white px-4 py-2 rounded">Cancelar</button>
          </form>
        </div>
      </div>

      <div id="sectionPreventivos" class="section-content bg-white p-6 rounded-lg shadow hidden">
        <h2 class="text-2xl font-bold mb-4">Mantenimiento Preventivo</h2>
        <button onclick="showForm('preventivo')" class="bg-green-600 text-white px-4 py-2 rounded mb-4">+ Programar Preventivo</button>
        <div id="preventivosList"></div>
        <div id="preventivoForm" class="hidden mt-4 p-4 border rounded bg-gray-50">
          <h3 class="font-bold mb-2">Programar Mantenimiento</h3>
          <form onsubmit="savePreventivo(event)">
            <input type="hidden" id="prevId">
            <select id="prevVehiculo" required class="border p-2 rounded w-full mb-2"></select>
            <select id="prevTipo" required class="border p-2 rounded w-full mb-2"></select>
            <input type="date" id="prevFecha" class="border p-2 rounded w-full mb-2">
            <input type="number" id="prevKm" placeholder="Kilometraje programado" class="border p-2 rounded w-full mb-2">
            <select id="prevEstado" class="border p-2 rounded w-full mb-2">
              <option value="pendiente">Pendiente</option>
              <option value="en_proceso">En Proceso</option>
              <option value="completado">Completado</option>
              <option value="cancelado">Cancelado</option>
            </select>
            <textarea id="prevObs" placeholder="Observaciones" class="border p-2 rounded w-full mb-2"></textarea>
            <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded">Guardar</button>
            <button type="button" onclick="hideForm('preventivo')" class="bg-gray-400 text-white px-4 py-2 rounded">Cancelar</button>
          </form>
        </div>
      </div>

      <!-- Correctivos, Órdenes, Historial, Reportes, Alertas, Usuarios: similar -->
      <!-- Por brevedad, aquí solo pongo la estructura, pero el código JavaScript completo lo incluyo a continuación -->
      <div id="sectionCorrectivos" class="section-content bg-white p-6 rounded-lg shadow hidden">
        <h2 class="text-2xl font-bold mb-4">Mantenimiento Correctivo</h2>
        <button onclick="showForm('correctivo')" class="bg-yellow-600 text-white px-4 py-2 rounded mb-4">+ Reportar Avería</button>
        <div id="correctivosList"></div>
        <div id="correctivoForm" class="hidden mt-4 p-4 border rounded bg-gray-50">
          <!-- Campos definidos en JS -->
          <form onsubmit="saveCorrectivo(event)">
            <div id="correctivoFields"></div>
            <button type="submit" class="bg-yellow-600 text-white px-4 py-2 rounded">Guardar</button>
            <button type="button" onclick="hideForm('correctivo')" class="bg-gray-400 text-white px-4 py-2 rounded">Cancelar</button>
          </form>
        </div>
      </div>

      <div id="sectionOrdenes" class="section-content bg-white p-6 rounded-lg shadow hidden">
        <h2 class="text-2xl font-bold mb-4">Órdenes de Trabajo</h2>
        <div id="ordenesList"></div>
      </div>

      <div id="sectionHistorial" class="section-content bg-white p-6 rounded-lg shadow hidden">
        <h2 class="text-2xl font-bold mb-4">Historial de Mantenimiento</h2>
        <select id="historialVehiculo" class="border p-2 rounded w-full mb-4"></select>
        <div id="historialContent"></div>
      </div>

      <div id="sectionReportes" class="section-content bg-white p-6 rounded-lg shadow hidden">
        <h2 class="text-2xl font-bold mb-4">Reportes y Estadísticas</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-4 border rounded"><h3 class="font-bold">Fallas por Vehículo</h3><div id="reporteFallas"></div></div>
          <div class="p-4 border rounded"><h3 class="font-bold">Costos por Vehículo</h3><div id="reporteCostos"></div></div>
          <div class="p-4 border rounded"><h3 class="font-bold">Cumplimiento Preventivos</h3><div id="reporteCumplimiento"></div></div>
          <div class="p-4 border rounded"><h3 class="font-bold">Disponibilidad de Flota</h3><div id="reporteDisponibilidad"></div></div>
        </div>
      </div>

      <div id="sectionAlertas" class="section-content bg-white p-6 rounded-lg shadow hidden">
        <h2 class="text-2xl font-bold mb-4">🔔 Alertas</h2>
        <div id="alertasList"></div>
      </div>

      <div id="sectionUsuarios" class="section-content bg-white p-6 rounded-lg shadow hidden">
        <h2 class="text-2xl font-bold mb-4">👥 Gestión de Usuarios</h2>
        <button onclick="showForm('usuario')" class="bg-indigo-600 text-white px-4 py-2 rounded mb-4">+ Crear Usuario</button>
        <div id="usuariosList"></div>
        <div id="usuarioForm" class="hidden mt-4 p-4 border rounded bg-gray-50">
          <form onsubmit="saveUsuario(event)">
            <input type="email" id="userEmail" placeholder="Email" required class="border p-2 rounded w-full mb-2">
            <input type="text" id="userNombre" placeholder="Nombre" required class="border p-2 rounded w-full mb-2">
            <select id="userRol" class="border p-2 rounded w-full mb-2">
              <option value="admin">Admin</option>
              <option value="jefe">Jefe</option>
              <option value="tecnico">Técnico</option>
              <option value="supervisor">Supervisor</option>
            </select>
            <input type="password" id="userPass" placeholder="Contraseña temporal" required class="border p-2 rounded w-full mb-2">
            <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded">Guardar</button>
            <button type="button" onclick="hideForm('usuario')" class="bg-gray-400 text-white px-4 py-2 rounded">Cancelar</button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <footer class="bg-white shadow-inner p-4 text-center text-gray-500 text-sm">
    TRANSNUPERSA S.A. - Sistema de Gestión de Mantenimiento Vehicular
  </footer>
</div>

<script>
  // ============================================================
  // CONFIGURACIÓN DE SUPABASE
  // ============================================================
  const SUPABASE_URL = 'https://tu-proyecto.supabase.co';  // REEMPLAZAR
  const SUPABASE_KEY = 'tu-clave-publica';                // REEMPLAZAR
  const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  // ============================================================
  // ESTADO GLOBAL
  // ============================================================
  let currentUser = null;
  let currentRol = null;

  // ============================================================
  // FUNCIONES DE AUTENTICACIÓN
  // ============================================================
  async function login(e) {
    e.preventDefault();
    const email = document.getElementById('loginEmail').value;
    const password = document.getElementById('loginPassword').value;
    const { data, error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) { alert('Error: ' + error.message); return; }
    await fetchUserData(data.user.id);
  }

  async function register(e) {
    e.preventDefault();
    const nombre = document.getElementById('regName').value;
    const email = document.getElementById('regEmail').value;
    const password = document.getElementById('regPassword').value;
    const rol = document.getElementById('regRol').value;
    // Crear usuario en auth
    const { data, error } = await supabase.auth.signUp({ email, password });
    if (error) { alert('Error: ' + error.message); return; }
    // Insertar en tabla usuarios
    const { error: insertError } = await supabase
      .from('usuarios')
      .insert([{ id: data.user.id, email, nombre, rol }]);
    if (insertError) { alert('Error al guardar perfil: ' + insertError.message); return; }
    alert('Registro exitoso. Ahora inicia sesión.');
    showLogin();
  }

  async function fetchUserData(userId) {
    const { data, error } = await supabase
      .from('usuarios')
      .select('*')
      .eq('id', userId)
      .single();
    if (error) { alert('Error al obtener perfil'); return; }
    currentUser = data;
    currentRol = data.rol;
    updateUIAfterLogin();
  }

  function updateUIAfterLogin() {
    document.getElementById('authButtons').classList.add('hidden');
    document.getElementById('userInfo').classList.remove('hidden');
    document.getElementById('userName').textContent = currentUser.nombre || currentUser.email;
    document.getElementById('userRole').textContent = currentUser.rol.toUpperCase();
    document.getElementById('loginScreen').classList.add('hidden');
    document.getElementById('registerScreen').classList.add('hidden');
    document.getElementById('dashboard').classList.remove('hidden');
    // Mostrar opciones de admin
    if (currentRol === 'admin') {
      document.getElementById('adminUsersBtn').classList.remove('hidden');
    }
    // Cargar datos iniciales
    loadVehiculos();
    loadPreventivos();
    loadCorrectivos();
    loadOrdenes();
    loadAlertas();
    loadReportes();
    loadUsuarios();
    cargarSelects();
    showSection('vehiculos');
  }

  async function logout() {
    await supabase.auth.signOut();
    location.reload();
  }

  function showLogin() {
    document.getElementById('loginScreen').classList.remove('hidden');
    document.getElementById('registerScreen').classList.add('hidden');
  }
  function showRegister() {
    document.getElementById('loginScreen').classList.add('hidden');
    document.getElementById('registerScreen').classList.remove('hidden');
  }

  // ============================================================
  // NAVEGACIÓN ENTRE SECCIONES
  // ============================================================
  function showSection(section) {
    document.querySelectorAll('.section-content').forEach(el => el.classList.add('hidden'));
    const map = {
      vehiculos: 'sectionVehiculos',
      preventivos: 'sectionPreventivos',
      correctivos: 'sectionCorrectivos',
      ordenes: 'sectionOrdenes',
      historial: 'sectionHistorial',
      reportes: 'sectionReportes',
      alertas: 'sectionAlertas',
      usuarios: 'sectionUsuarios'
    };
    const target = document.getElementById(map[section]);
    if (target) target.classList.remove('hidden');
    // Recargar datos al cambiar de sección
    if (section === 'vehiculos') loadVehiculos();
    if (section === 'preventivos') loadPreventivos();
    if (section === 'correctivos') loadCorrectivos();
    if (section === 'ordenes') loadOrdenes();
    if (section === 'historial') cargarSelectsHistorial();
    if (section === 'reportes') loadReportes();
    if (section === 'alertas') loadAlertas();
    if (section === 'usuarios') loadUsuarios();
  }

  // ============================================================
  // GESTIÓN DE VEHÍCULOS
  // ============================================================
  async function loadVehiculos() {
    const { data, error } = await supabase.from('vehiculos').select('*').order('id');
    if (error) { console.error(error); return; }
    const container = document.getElementById('vehiculosList');
    if (data.length === 0) {
      container.innerHTML = '<p class="text-gray-500">No hay vehículos registrados.</p>';
      return;
    }
    let html = '';
    data.forEach(v => {
      html += `<div class="card bg-gray-50 p-4 rounded-lg border">
        <h3 class="font-bold">${v.placa} - ${v.marca} ${v.modelo}</h3>
        <p class="text-sm">Kilometraje: ${v.kilometraje} km | Estado: <span class="badge bg-blue-100">${v.estado}</span></p>
        <div class="mt-2 flex gap-2">
          <button onclick="editVehiculo(${v.id})" class="text-blue-600 hover:underline">Editar</button>
          <button onclick="deleteVehiculo(${v.id})" class="text-red-600 hover:underline">Eliminar</button>
        </div>
      </div>`;
    });
    container.innerHTML = html;
  }

  async function saveVehiculo(e) {
    e.preventDefault();
    const id = document.getElementById('vehiculoId').value;
    const data = {
      placa: document.getElementById('vPlaca').value,
      marca: document.getElementById('vMarca').value,
      modelo: document.getElementById('vModelo').value,
      año: parseInt(document.getElementById('vAnio').value) || null,
      chasis: document.getElementById('vChasis').value,
      motor: document.getElementById('vMotor').value,
      tipo: document.getElementById('vTipo').value,
      capacidad: parseFloat(document.getElementById('vCapacidad').value) || null,
      combustible: document.getElementById('vCombustible').value,
      kilometraje: parseInt(document.getElementById('vKilometraje').value) || 0,
      fecha_adquisicion: document.getElementById('vFechaAdq').value || null,
      estado: document.getElementById('vEstado').value,
      conductor: document.getElementById('vConductor').value,
      observaciones: document.getElementById('vObservaciones').value,
    };
    let error;
    if (id) {
      ({ error } = await supabase.from('vehiculos').update(data).eq('id', id));
    } else {
      ({ error } = await supabase.from('vehiculos').insert([data]));
    }
    if (error) { alert('Error: ' + error.message); return; }
    hideForm('vehiculo');
    loadVehiculos();
  }

  async function editVehiculo(id) {
    const { data, error } = await supabase.from('vehiculos').select('*').eq('id', id).single();
    if (error) return;
    document.getElementById('vehiculoId').value = data.id;
    document.getElementById('vPlaca').value = data.placa;
    document.getElementById('vMarca').value = data.marca;
    document.getElementById('vModelo').value = data.modelo;
    document.getElementById('vAnio').value = data.año || '';
    document.getElementById('vChasis').value = data.chasis || '';
    document.getElementById('vMotor').value = data.motor || '';
    document.getElementById('vTipo').value = data.tipo || '';
    document.getElementById('vCapacidad').value = data.capacidad || '';
    document.getElementById('vCombustible').value = data.combustible || '';
    document.getElementById('vKilometraje').value = data.kilometraje || '';
    document.getElementById('vFechaAdq').value = data.fecha_adquisicion || '';
    document.getElementById('vEstado').value = data.estado;
    document.getElementById('vConductor').value = data.conductor || '';
    document.getElementById('vObservaciones').value = data.observaciones || '';
    document.getElementById('vehiculoForm').classList.remove('hidden');
  }

  async function deleteVehiculo(id) {
    if (!confirm('¿Eliminar este vehículo?')) return;
    const { error } = await supabase.from('vehiculos').delete().eq('id', id);
    if (error) { alert('Error: ' + error.message); return; }
    loadVehiculos();
  }

  // ============================================================
  // FUNCIONES AUXILIARES PARA FORMULARIOS
  // ============================================================
  function showForm(type) {
    const map = {
      vehiculo: 'vehiculoForm',
      preventivo: 'preventivoForm',
      correctivo: 'correctivoForm',
      usuario: 'usuarioForm'
    };
    const el = document.getElementById(map[type]);
    if (el) el.classList.remove('hidden');
    // Resetear formulario
    if (type === 'vehiculo') document.getElementById('vehiculoId').value = '';
  }
  function hideForm(type) {
    const map = {
      vehiculo: 'vehiculoForm',
      preventivo: 'preventivoForm',
      correctivo: 'correctivoForm',
      usuario: 'usuarioForm'
    };
    const el = document.getElementById(map[type]);
    if (el) el.classList.add('hidden');
  }

  // ============================================================
  // MANTENIMIENTO PREVENTIVO
  // ============================================================
  async function loadPreventivos() {
    const { data, error } = await supabase
      .from('mantenimientos_preventivos')
      .select('*, vehiculos(placa), tipos_mantenimiento(nombre)')
      .order('id', { ascending: false });
    if (error) { console.error(error); return; }
    const container = document.getElementById('preventivosList');
    if (data.length === 0) {
      container.innerHTML = '<p>No hay mantenimientos preventivos.</p>';
      return;
    }
    let html = '<div class="grid gap-2">';
    data.forEach(p => {
      html += `<div class="border p-3 rounded flex justify-between items-center">
        <div><strong>${p.vehiculos?.placa || 'N/A'}</strong> - ${p.tipos_mantenimiento?.nombre || 'Sin tipo'} <br>
        <span class="text-sm">Programado: ${p.fecha_programada || 'N/A'} | Km: ${p.kilometraje_programado || 'N/A'}</span>
        <span class="badge ${p.estado === 'pendiente' ? 'bg-yellow-200' : p.estado === 'completado' ? 'bg-green-200' : 'bg-gray-200'}">${p.estado}</span>
        </div>
        <div>
          <button onclick="editPreventivo(${p.id})" class="text-blue-600">Editar</button>
          <button onclick="deletePreventivo(${p.id})" class="text-red-600">Eliminar</button>
        </div>
      </div>`;
