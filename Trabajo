  async function cargarSelects() {
    // Vehículos para preventivos y correctivos
    const { data: vehiculos } = await supabase.from('vehiculos').select('id, placa');
    const selects = ['prevVehiculo', 'correctivoVehiculo', 'historialVehiculo'];
    selects.forEach(id => {
      const sel = document.getElementById(id);
      if (!sel) return;
      sel.innerHTML = '<option value="">Seleccionar...</option>';
      vehiculos.forEach(v => {
        sel.innerHTML += `<option value="${v.id}">${v.placa}</option>`;
      });
    });
    // Tipos de mantenimiento
    const { data: tipos } = await supabase.from('tipos_mantenimiento').select('id, nombre');
    const selTipo = document.getElementById('prevTipo');
    if (selTipo) {
      selTipo.innerHTML = '<option value="">Seleccionar...</option>';
      tipos.forEach(t => {
        selTipo.innerHTML += `<option value="${t.id}">${t.nombre}</option>`;
      });
    }
    // Tipos de avería
    const { data: averias } = await supabase.from('tipos_averia').select('id, nombre');
    const selAveria = document.getElementById('correctivoTipoAveria');
    if (selAveria) {
      selAveria.innerHTML = '<option value="">Seleccionar...</option>';
      averias.forEach(a => {
        selAveria.innerHTML += `<option value="${a.id}">${a.nombre}</option>`;
      });
    }
  }

