  async function savePreventivo(e) {
    e.preventDefault();
    const id = document.getElementById('prevId').value;
    const data = {
      vehiculo_id: document.getElementById('prevVehiculo').value,
      tipo_mantenimiento_id: document.getElementById('prevTipo').value,
      fecha_programada: document.getElementById('prevFecha').value || null,
      kilometraje_programado: parseInt(document.getElementById('prevKm').value) || null,
      estado: document.getElementById('prevEstado').value,
      observaciones: document.getElementById('prevObs').value
    };
    let error;
    if (id) {
      ({ error } = await supabase.from('mantenimientos_preventivos').update(data).eq('id', id));
    } else {
      ({ error } = await supabase.from('mantenimientos_preventivos').insert([data]));
      // Generar orden de trabajo automáticamente
      if (!error) {
        const { data: newPrev } = await supabase.from('mantenimientos_preventivos').select('id').order('id', { ascending: false }).limit(1);
        if (newPrev && newPrev.length > 0) {
          await supabase.from('ordenes_trabajo').insert([{
            tipo: 'preventivo',
            referencia_id: newPrev[0].id,
            fecha_creacion: new Date().toISOString().split('T')[0],
            estado: 'pendiente'
          }]);
        }
      }
    }
    if (error) { alert('Error: ' + error.message); return; }
    hideForm('preventivo');
    loadPreventivos();
  }

