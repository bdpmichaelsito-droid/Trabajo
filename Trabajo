  async function loadOrdenes() {
    const { data, error } = await supabase
      .from('ordenes_trabajo')
      .select('*, usuarios(nombre), mantenimientos_preventivos(*), mantenimientos_correctivos(*)')
      .order('id', { ascending: false });
    if (error) { console.error(error); return; }
    const container = document.getElementById('ordenesList');
    if (data.length === 0) {
      container.innerHTML = '<p>No hay órdenes de trabajo.</p>';
      return;
    }
    let html = '<div class="grid gap-2">';
    data.forEach(o => {
      html += `<div class="border p-3 rounded">
        <strong>Orden #${o.id}</strong> - Tipo: ${o.tipo} | Estado: <span class="badge bg-purple-100">${o.estado}</span><br>
        Técnico: ${o.usuarios?.nombre || 'Sin asignar'} | Costo: $${o.costo_total || 0}
        <div class="mt-1">
          <button onclick="asignarOrden(${o.id})" class="text-blue-600 text-sm">Asignar Técnico</button>
          <button onclick="actualizarEstadoOrden(${o.id})" class="text-green-600 text-sm">Cambiar Estado</button>
        </div>
      </div>`;
    });
    html += '</div>';
    container.innerHTML = html;
  }

  // ============================================================
  // ALERTAS (simuladas desde consultas)
  // ============================================================
  async function loadAlertas() {
    const container = document.getElementById('alertasList');
    // Buscar mantenimientos próximos (fecha <= 7 días)
    const hoy = new Date();
    const semana = new Date(hoy.getTime() + 7*24*60*60*1000).toISOString().split('T')[0];
    const { data: proximos } = await supabase
      .from('mantenimientos_preventivos')
      .select('*, vehiculos(placa)')
      .gte('fecha_programada', hoy.toISOString().split('T')[0])
      .lte('fecha_programada', semana)
      .eq('estado', 'pendiente');
    let html = '<h3 class="font-bold">Próximos mantenimientos</h3><ul>';
    (proximos || []).forEach(p => {
      html += `<li>🔔 ${p.vehiculos?.placa} - ${p.fecha_programada} (${p.kilometraje_programado} km)</li>`;
    });
    html += '</ul>';
    // Vencidos
    const { data: vencidos } = await supabase
      .from('mantenimientos_preventivos')
      .select('*, vehiculos(placa)')
      .lt('fecha_programada', hoy.toISOString().split('T')[0])
      .eq('estado', 'pendiente');
    html += '<h3 class="font-bold mt-4">Vencidos</h3><ul>';
    (vencidos || []).forEach(p => {
      html += `<li>⚠️ ${p.vehiculos?.placa} - vencido desde ${p.fecha_programada}</li>`;
    });
    html += '</ul>';
    container.innerHTML = html;
  }

